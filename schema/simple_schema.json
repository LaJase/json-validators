{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Utilisateur",
  "type": "object",
  "required": ["id", "nom", "email", "age"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Identifiant unique"
    },
    "nom": {
      "type": "string",
      "minLength": 2,
      "description": "Nom complet"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Adresse email"
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 150,
      "description": "Âge en années"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["admin", "user", "moderateur"]
      },
      "description": "Rôles attribués"
    }
  },
  "additionalProperties": false
}
